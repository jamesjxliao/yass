# Data provider — production runs Sharadar (Nasdaq Data Link); FMP is the standby.
# DATA_PROVIDER: auto | sharadar | fmp | mock. "auto" prefers Sharadar when its
# key is set, then FMP, then mock. Rollback to FMP = DATA_PROVIDER=fmp (pair it
# with an FMP-era database — never run one provider against the other's DB).
NASDAQ_DATA_LINK_API_KEY=your_nasdaq_data_link_key
FMP_API_KEY=your_fmp_api_key
DATA_PROVIDER=auto
ALPACA_API_KEY=your_alpaca_key_id
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_PAPER=true
ETORO_API_KEY=your_etoro_public_api_key
ETORO_USER_KEY=your_etoro_user_key
ETORO_DEMO=true
