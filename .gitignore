# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/

# Environment
.env

# Data
data/*.duckdb
data/*.duckdb.wal
data/*.json
data/*.png
data/*.txt
!data/sp400/

# Results — bulk regenerable output stays ignored; the trading record (trade
# logs + cash-flow ledger) is versioned: it is hand-curated and cannot be
# reconstructed, unlike evaluation/chart output.
results/*
!results/trades/
!results/tracking/
results/tracking/tracking_report.json

# Autoresearch
*.log

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store

# coverage artifacts
.coverage
htmlcov/
data/*.bak*
data/*.duckdb.bak*

# Lazy Prices experiment (checkpoints regenerable via fetch_lazy_prices.py)
data/lazy_prices/*
!data/lazy_prices/cik_overrides.json
# SF2 insider data: licensed Sharadar raw rows — local-only, never committed
# (regenerable via fetch_insider_sf2.py)
data/insider_sf2/
# SF3A institutional 13F summary: licensed Sharadar raw rows — local-only
# (regenerable via fetch_sf3a.py)
data/sf3a/
# HF earnings-call transcripts (MIT) + derived metrics — too large for git
data/transcripts/

# Sharadar EVENTS raw rows: licensed, local-only (regenerable via events_study.py fetch)
data/events/*

# JKP factor library downloads (CC BY-NC 4.0, regenerable via jkp_mega_scan.py fetch)
data/jkp_mega/*
