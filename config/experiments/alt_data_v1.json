{
  "name": "alt_data_v1",
  "hypothesis": "Do analyst targets and insider buying add value to our best strategy?",
  "base_config": "config/default.yaml",
  "variations": [
    {
      "name": "best_current",
      "signals": [
        {"name": "momentum_12m", "weight": 0.30},
        {"name": "earnings_growth", "weight": 0.30},
        {"name": "quality_score", "weight": 0.15},
        {"name": "low_leverage_growth", "weight": 0.25}
      ]
    },
    {
      "name": "add_analyst_upside",
      "signals": [
        {"name": "momentum_12m", "weight": 0.25},
        {"name": "earnings_growth", "weight": 0.25},
        {"name": "quality_score", "weight": 0.10},
        {"name": "low_leverage_growth", "weight": 0.20},
        {"name": "analyst_upside", "weight": 0.20}
      ]
    },
    {
      "name": "add_insider_buying",
      "signals": [
        {"name": "momentum_12m", "weight": 0.25},
        {"name": "earnings_growth", "weight": 0.25},
        {"name": "quality_score", "weight": 0.10},
        {"name": "low_leverage_growth", "weight": 0.20},
        {"name": "insider_buying", "weight": 0.20}
      ]
    },
    {
      "name": "add_both_alt_data",
      "signals": [
        {"name": "momentum_12m", "weight": 0.20},
        {"name": "earnings_growth", "weight": 0.20},
        {"name": "quality_score", "weight": 0.10},
        {"name": "low_leverage_growth", "weight": 0.15},
        {"name": "analyst_upside", "weight": 0.15},
        {"name": "insider_buying", "weight": 0.20}
      ]
    }
  ],
  "backtest": {
    "start_date": "2017-01-01",
    "end_date": "2026-01-01",
    "rebalance_frequency": "monthly",
    "top_n": 20,
    "walk_forward": true
  },
  "guardrails": {
    "holdout_start": "2024-01-01",
    "max_experiments": 50,
    "min_sharpe_threshold": 0.3,
    "min_sample_size": 30
  }
}
